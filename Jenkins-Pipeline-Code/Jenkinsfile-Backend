pipeline {
    agent any     

    environment  {
        SCANNER_HOME = tool('sonar-scanner')
        SONAR_TOKEN = credentials('sonar-token')

        AWS_ACCOUNT_ID = credentials('ACCOUNT_ID')
        AWS_ECR_REPO_NAME = credentials('ECR_BACKEND_FLASK')
        AWS_DEFAULT_REGION = 'us-east-1'
        REPOSITORY_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/"

        GIT_USER_NAME = 'Ahmedlekan'
        GIT_REPO_NAME = 'aws-bootcamp-cruddur-2023'
        GIT_TOKEN = credentials('github-token')
    }

    stages {

        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        
        stage('Checkout from Git') {
            steps {
                git branch: 'main', 
                    credentialsId: 'github-creds', 
                    url: 'https://github.com/Ahmedlekan/aws-bootcamp-cruddur-2023.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Application-code/backend-flask') {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=backend-python \
                        -Dsonar.projectKey=backend-python \
                        -Dsonar.sources=. \
                        -Dsonar.language=py \
                        -Dsonar.sourceEncoding=UTF-8
                        '''
                    }
                }
            }
        }

        stage('Quality Gates') {
            steps { 
                echo "Running Quality Gates to verify backend code quality"
                script {
                    timeout(time: 1, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Trivy File Scan') {
            steps {
                dir('Application-code/backend-flask') {
                    sh 'trivy fs . > trivyfs-backend.txt'
                }
            }
        }

        stage("Docker Image Build") {
            steps {
                script {
                    dir('Application-code/backend-flask') {
                        sh 'docker system prune -f'
                        sh 'docker container prune -f'
                        sh 'docker build -t ${AWS_ECR_REPO_NAME} .'
                    }
                }
            }
        }

        stage("ECR Image Pushing") {
            steps {
                script {
                    sh '''
                    aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | \
                    docker login --username AWS --password-stdin ${REPOSITORY_URI}
                    '''

                    sh '''
                    docker tag ${AWS_ECR_REPO_NAME} \
                    ${REPOSITORY_URI}${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}
                    '''

                    sh '''
                    docker push \
                    ${REPOSITORY_URI}${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage("Trivy Image Scan") {
            steps {
                sh '''
                trivy image \
                ${REPOSITORY_URI}${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} \
                > trivyimage-backend.txt
                '''
            }
        }
    }
}